FROM opencode-docker-ubuntu:latest

RUN curl -fsSL https://raw.githubusercontent.com/btriapitsyn/openchamber/main/scripts/install.sh | bash

WORKDIR /root

# Use a shell-based ENTRYPOINT to allow variable expansion
ENTRYPOINT ["/usr/bin/tini", "--", "sh", "-c", "openchamber serve --port 4096 --host 0.0.0.0 --foreground --ui-password ${UI_PASSWORD}"]