# OpenCode Docker Environment Configuration
# Copy this file to .env and fill in your values

# OpenChamber Configuration (docker-compose -f docker-compose.openchamber.yml up)
OPENCHAMBER_UI_PASSWORD=change-me

# Network Configuration
OPENCODE_IP=127.0.0.1
OPENCODE_PORT=4096

# MCP API Keys (used via {env:KEY_NAME} in opencode.json)
# Get your keys from:
# - Brave Search API: https://brave.com/search/api/
# - Tavily API: https://tavily.com/
# - Exa API: https://exa.ai/
BRAVE_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# OpenCode Server Password (optional, for authentication)
# OPENCODE_SERVER_PASSWORD=

# Optional: Additional environment variables for OpenCode
# OPENCODE_EXTRA_ARGS=--verbose
